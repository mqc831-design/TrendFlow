# ============================================================
# TrendFlow 后端环境变量
# 复制此文件为 .env 后编辑
# ============================================================

# ----- 服务 -----
PORT=3001
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ----- 数据源（设为空字符串 "" 则使用内置 Mock 数据）-----
WEIBO_API_URL=https://weibo.com/ajax/side/hotSearch
ZHIHU_API_URL=https://www.zhihu.com/api/v3/feed/topstory/hot-list-web?limit=50
BILIBILI_API_URL=https://api.bilibili.com/x/web-interface/popular

# ----- 缓存 -----
CACHE_TTL=600

# ----- 调试（仅开发环境）-----
MOCK_FAIL_WEIBO=false
MOCK_FAIL_ZHIHU=false
MOCK_FAIL_BILIBILI=false
